{
  "Name": "CropType",
  "A": {"Attribute_name":"CropTypeId", "Use":"r", "Type": "xs:ID", "length": "min. 4 to max. 14", "comment": "Unique identifier of CropType\nFormat: (CTP|CTP-)([0–9])+\nRecords generated on MICS\nhave negative IDs"},
  "B": {"Attribute_name":"CropTypeDesignator", "Use":"r", "Type": "xs:string", "length": "max. 32", "comment": "Name of the crop"},
  "C": {"Attribute_name":"ProductGroupIdRef", "Use":"o", "Type": "xs:IDREF", "Ref_id": "PGP", "length": "min. 4 to max. 14", "comment": "Reference to XML element ProductGroup\nFormat: (PGP|PGP-)([0–9])+"},
  "includes": {"CVT": {"Use": "o"}}
}
