{
  "Name": "CropVariety",
  "A": {"Attribute_name":"CropVarietyId", "Use":"r", "Type": "xs:ID", "length": "min. 4 to max. 14", "comment": "Unique identifier of CropVariety\nFormat: (CVT|CVT-)([0–9])+\nRecords generated on MICS\nhave negative IDs"},
  "B": {"Attribute_name":"CropVarietyDesignator", "Use":"r", "Type": "xs:string", "length": "max. 32", "comment": "Name of the CropVariety"},
  "C": {"Attribute_name":"ProductIdRef", "Use":"o", "Type": "xs:IDREF", "Ref_id": "PDT", "length": "min. 4 to max. 14", "comment": "Reference to XML element Product\nFormat: (PDT|PDT-)([0–9])+"},
  "includes": {}
}
