  <property name="styleSheet">
   <string notr="true">
/* === Global === */
* {
  font-family: "Segoe UI", sans-serif;
  font-size: 9pt;
}

/* === Buttons === */
QPushButton {
  background-color: #3574b0;
  color: white;
  border: none;
  border-radius: 3px;
  padding: 4px 10px;
  font-size: 8pt;
}
QPushButton:hover {
  background-color: #2a5f8f;
}
QPushButton:pressed {
  background-color: #1e4a6e;
}
QPushButton:disabled {
  background-color: palette(mid);
  color: palette(midlight);
}

/* === Inputs === */
QLineEdit, QPlainTextEdit, QTextEdit {
  border: 1px solid palette(mid);
  border-radius: 3px;
  padding: 2px 4px;
  background: palette(base);
}
QLineEdit:focus, QPlainTextEdit:focus, QTextEdit:focus {
  border: 1px solid #3574b0;
}

/* === Combo boxes === */
QComboBox {
  border: 1px solid palette(mid);
  border-radius: 3px;
  padding: 2px 4px;
  background: palette(base);
}
QComboBox:hover {
  border: 1px solid #3574b0;
}
QComboBox::drop-down {
  border: none;
  width: 20px;
}
QComboBox QAbstractItemView {
  color: palette(text);
  background: palette(base);
  selection-color: palette(highlighted-text);
  selection-background-color: palette(highlight);
}

/* === Group boxes === */
QGroupBox {
  border: 1px solid palette(mid);
  border-radius: 3px;
  margin-top: 8px;
  padding-top: 8px;
  font-weight: bold;
  font-size: 8pt;
}
QGroupBox::title {
  subcontrol-origin: margin;
  left: 8px;
  padding: 0 3px;
}

/* === Labels === */
QLabel {
  font-size: 8pt;
}

/* === Table === */
QTableWidget, QTableView {
  border: 1px solid palette(mid);
  border-radius: 3px;
  gridline-color: palette(midlight);
}
QHeaderView::section {
  background-color: palette(window);
  border: none;
  border-bottom: 1px solid palette(mid);
  border-right: 1px solid palette(midlight);
  padding: 3px 6px;
  font-weight: bold;
  font-size: 8pt;
}

/* === Spin boxes === */
QSpinBox, QDoubleSpinBox, QDateEdit, QTimeEdit {
  border: 1px solid palette(mid);
  border-radius: 3px;
  padding: 2px 4px;
  background: palette(base);
}

/* === Format sub-tabs (Shapefile / ISO-XML) — light green, a touch ===
   === lighter than the green navigation sidebar (the main selector). === */
QTabWidget#tabFormat::pane {
  border: 1px solid #b6d4b8;
  border-radius: 3px;
  background: palette(base);
}
QTabWidget#tabFormat QTabBar::tab {
  background: #e3f0e4;
  color: #2f5233;
  border: 1px solid #b6d4b8;
  border-bottom: none;
  border-top-left-radius: 3px;
  border-top-right-radius: 3px;
  padding: 5px 14px;
  margin-right: 2px;
  font-weight: bold;
}
QTabWidget#tabFormat QTabBar::tab:selected {
  background: #bcdcbe;
  color: #1e3a21;
  border-bottom: 2px solid #4a7c4e;
}
QTabWidget#tabFormat QTabBar::tab:hover:!selected {
  background: #d2e7d4;
}
   </string>
