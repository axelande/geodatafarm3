  <property name="styleSheet"><string notr="true">
/* === Global === */
* {
  font-family: "Segoe UI", sans-serif;
  font-size: 9pt;
}

/* === Tab bars === */
QTabWidget::pane {
  border: 1px solid palette(mid);
  border-radius: 3px;
  background: palette(base);
}
QTabBar::tab {
  background: palette(window);
  border: 1px solid palette(mid);
  border-bottom: none;
  border-top-left-radius: 3px;
  border-top-right-radius: 3px;
  padding: 4px 10px;
  margin-right: 1px;
  font-size: 8pt;
}
QTabBar::tab:selected {
  background: palette(base);
  border-bottom: 2px solid #3574b0;
  color: #3574b0;
}
QTabBar::tab:hover:!selected {
  background: palette(midlight);
}

/* === Buttons === */
QPushButton {
  background-color: #3574b0;
  color: white;
  border: none;
  border-radius: 3px;
  padding: 4px 10px;
  font-size: 8pt;
}
QPushButton:hover {
  background-color: #2a5f8f;
}
QPushButton:pressed {
  background-color: #1e4a6e;
}
QPushButton:disabled {
  background-color: palette(mid);
  color: palette(midlight);
}

/* === Inputs === */
QLineEdit, QPlainTextEdit, QTextEdit {
  border: 1px solid palette(mid);
  border-radius: 3px;
  padding: 2px 4px;
  background: palette(base);
}
QLineEdit:focus, QPlainTextEdit:focus, QTextEdit:focus {
  border: 1px solid #3574b0;
}

/* === Combo boxes === */
QComboBox {
  border: 1px solid palette(mid);
  border-radius: 3px;
  padding: 2px 4px;
  background: palette(base);
}
QComboBox:hover {
  border: 1px solid #3574b0;
}
QComboBox::drop-down {
  border: none;
  width: 20px;
}
QComboBox QAbstractItemView {
  color: palette(text);
  background: palette(base);
  selection-color: palette(highlighted-text);
  selection-background-color: palette(highlight);
}

/* === Lists === */
QListWidget {
  border: 1px solid palette(mid);
  border-radius: 3px;
  background: palette(base);
}

/* === Group boxes === */
QGroupBox {
  border: 1px solid palette(mid);
  border-radius: 3px;
  margin-top: 8px;
  padding-top: 8px;
  font-weight: bold;
  font-size: 8pt;
}
QGroupBox::title {
  subcontrol-origin: margin;
  left: 8px;
  padding: 0 3px;
}

/* === Radio &amp; Check === */
QRadioButton, QCheckBox {
  spacing: 4px;
  font-size: 8pt;
}

/* === Labels === */
QLabel {
  font-size: 8pt;
}

/* === Calendar === */
QCalendarWidget {
  border: 1px solid palette(mid);
  border-radius: 3px;
}

/* === Table === */
QTableWidget, QTableView {
  border: 1px solid palette(mid);
  border-radius: 3px;
  gridline-color: palette(midlight);
}
QHeaderView::section {
  background-color: palette(window);
  border: none;
  border-bottom: 1px solid palette(mid);
  border-right: 1px solid palette(midlight);
  padding: 3px 6px;
  font-weight: bold;
  font-size: 8pt;
}

/* === Spin boxes === */
QSpinBox, QDoubleSpinBox, QDateEdit, QTimeEdit {
  border: 1px solid palette(mid);
  border-radius: 3px;
  padding: 2px 4px;
  background: palette(base);
}
QSpinBox:focus, QDoubleSpinBox:focus, QDateEdit:focus, QTimeEdit:focus {
  border: 1px solid #3574b0;
}
